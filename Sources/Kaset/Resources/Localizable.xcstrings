          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Extensions are loaded at launch via the native WebKit extension API. Changes take effect after restarting Kaset."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las extensiones se cargan al iniciar mediante la API nativa de extensiones de WebKit. Los cambios se aplican después de reiniciar Kaset."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Extensions are loaded at launch via the native WebKit extension API. Changes take effect after restarting Kaset."
