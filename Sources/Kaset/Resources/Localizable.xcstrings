    "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off." : {
      "comment" : "Settings window → General tab (account, behavior, privacy, language, cache, updates, about).",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعطّل Liquid Glass وشريط الأوامر وواجهات Apple Intelligence حتى يتم إيقاف هذا الخيار."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vypne Liquid Glass, velitelský panel a Apple Inteligence UI povrchy, dokud není vypnuto."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktiverer flydende glas, kommandobjælken og Apple Intelligence UI overflader, indtil slukket."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktiviert Liquid Glass, die Befehlsleiste und Apple-Intelligence-Oberflächen, bis die Option wieder ausgeschaltet wird."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Απενεργοποιεί το υγρό γυαλί, τη γραμμή εντολών και τις επιφάνειες της Apple Intelligence UI μέχρι να αποσυνδεθούν."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desactiva Liquid Glass, la barra de comandos y las superficies de interfaz de Apple Intelligence hasta que se desactive."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poistaa Nestemäisen lasin, komentorivin ja Apple Intelligence UI -käyttöliittymän pinnat käytöstä, kunnes se kytketään pois päältä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désactive Liquid Glass, la barre de commandes et les surfaces d'interface Apple Intelligence jusqu'à sa désactivation."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menonaktifkan Liquid Glass, Command Bar, dan permukaan UI Apple Intelligence sampai dimatikan kembali."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se impostato su off, disattiva Liquid Glass, la barra dei comandi e la UI di Apple Intelligence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "液体ガラス、コマンドバー、およびApple Intelligence UIがオフになるまで表面化しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "끄기 전까지 Liquid Glass, Command Bar 및 Apple Intelligence UI 요소를 비활성화합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schakelt Liquid Glass, de opdrachtbalk en Apple Intelligence-UI uit tot dit weer wordt uitgeschakeld."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktiverer Flytende Glass, kommandobaren, og Apple Intelligence UI overflater inntil skrudde av."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyłącza Liquid Glass, pasek poleceń i elementy interfejsu Apple Intelligence, dopóki opcja nie zostanie wyłączona."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desativa o Liquid Glass, a Barra de comandos e as superfícies da interface Apple Intelligence até ser desativado."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desativa as superfícies de Vidro do Liquid, a Barra de Comando e a interface de Inteligência da Apple até ser desligada."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dezactivează lasul lichid, bara de comandă și suprafețele Apple Intelligence UI până la togled off."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отключает Liquid Glass, панель команд и элементы интерфейса Apple Intelligence, пока параметр не будет выключен."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stänger av Liquid Glass, kommandofältet och Apple Intelligence-gränssnitt tills det stängs av igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kapatılana kadar Liquid Glass'ı, Komut Çubuğu'nu ve Apple Intelligence arayüzlerini devre dışı bırakır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вимикає Liquid Glass, панель команд і елементи інтерфейсу Apple Intelligence, доки цей параметр не буде вимкнено."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Disables Liquid Glass, the Command Bar, and Apple Intelligence UI surfaces until toggled off."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
