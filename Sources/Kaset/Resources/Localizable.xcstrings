    "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again." : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يمكن لـ Kaset الوصول إلى إخراج الصوت الخاص به. افتح إعدادات النظام ← الخصوصية والأمان ← تسجيل الشاشة وصوت النظام وقم بتفعيل Kaset، ثم أعد تشغيل المعادل."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset kann nicht auf seine eigene Audioausgabe zugreifen. Öffne Systemeinstellungen → Datenschutz und Sicherheit → Bildschirm- und Systemaudioaufnahme, aktiviere Kaset und schalte dann den Equalizer erneut ein."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset no puede acceder a su propia salida de audio. Abre Configuración del Sistema → Privacidad y seguridad → Grabación de pantalla y audio del sistema, activa Kaset y vuelve a activar el ecualizador."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset n'a pas accès à sa propre sortie audio. Ouvrez Réglages Système → Confidentialité et sécurité → Enregistrement de l'écran et de l'audio système, activez Kaset, puis réactivez l'égaliseur."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset tidak dapat mengakses output audio-nya sendiri. Buka Pengaturan Sistem → Privasi & Keamanan → Perekaman Layar & Audio Sistem dan aktifkan Kaset, lalu aktifkan kembali equalizer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset non può accedere alla propria uscita audio. Apri Impostazioni di Sistema → Privacy e Sicurezza → Registrazione schermo e audio di sistema e abilita Kaset, quindi riattiva l'equalizzatore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset이 자체 오디오 출력에 접근할 수 없습니다. 시스템 설정 → 개인정보 보호 및 보안 → 화면 및 시스템 오디오 녹음에서 Kaset을 활성화한 후 이퀄라이저를 다시 켜주세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset heeft geen toegang tot de eigen audio-uitvoer. Open Systeeminstellingen → Privacy en beveiliging → Scherm- en systeemaudio-opname, schakel Kaset in en zet daarna de equalizer opnieuw aan."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset nie ma dostępu do własnego wyjścia audio. Otwórz Ustawienia systemowe → Prywatność i ochrona → Ekran i nagrywanie dźwięku systemowego i włącz Kaset, a następnie ponownie włącz korektor."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Kaset não consegue aceder à própria saída de áudio. Abra Definições do Sistema → Privacidade e segurança → Gravação do ecrã e áudio do sistema e ative o Kaset; depois ative novamente o equalizador."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset не может получить доступ к собственному аудиовыходу. Откройте Системные настройки → Конфиденциальность и безопасность → Запись экрана и системного аудио и включите Kaset, затем снова включите эквалайзер."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset kan inte komma åt sin egen ljudutgång. Öppna Systeminställningar → Integritet och säkerhet → Skärminspelning och systemljudinspelning, aktivera Kaset och slå sedan på equalizern igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset kendi ses çıkışına erişemiyor. Sistem Ayarları → Gizlilik ve Güvenlik → Ekran ve Sistem Sesi Kaydı'nı açıp Kaset'i etkinleştirin, ardından ekolayzırı tekrar açın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset не має доступу до власного звукового виходу. Відкрийте Системні налаштування → Конфіденційність і безпека → Запис екрана та системного звуку, увімкніть Kaset, а потім знову увімкніть еквалайзер."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset can't access its own audio output. Open System Settings → Privacy & Security → Screen & System Audio Recording and enable Kaset, then toggle the equalizer on again."
          }
        }
      }
    },
    "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ينشئ Kaset جلسات ذكاء اصطناعي جديدة لكل طلب. حدّث الحالة إذا انتهى تنزيل Apple Intelligence أو أصبح متاحًا أثناء فتح التطبيق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset erstellt für jede Anfrage eine neue KI-Sitzung. Aktualisiere den Status, wenn Apple Intelligence fertig geladen ist oder verfügbar wird, während die App geöffnet ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset crea sesiones nuevas de IA para cada solicitud. Actualiza el estado si Apple Intelligence termina de descargarse o pasa a estar disponible mientras la app está abierta."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset crée une nouvelle session d'IA pour chaque demande. Actualisez l'état si Apple Intelligence finit de se télécharger ou devient disponible pendant que l'app est ouverte."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kaset creates fresh AI sessions per request. Refresh the status if Apple Intelligence finishes downloading or becomes available while the app is open."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset membuat sesi AI baru untuk setiap permintaan. Segarkan status jika Apple Intelligence selesai diunduh atau menjadi tersedia saat app terbuka."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaset crea una nuova sessione AI per ogni richiesta. Aggiorna lo stato se Apple Intelligence termina il download o diventa disponibile mentre l'app è aperta."
