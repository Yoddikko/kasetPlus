          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "확장 프로그램은 실행 시 기본 WebKit 확장 프로그램 API를 통해 로드됩니다. 변경 사항은 KasetPlus을 다시 시작한 후 적용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
