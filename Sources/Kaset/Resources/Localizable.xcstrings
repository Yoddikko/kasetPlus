    "Extensions are loaded at launch via the native WebKit extension API. Changes take effect after restarting KasetPlus." : {
      "comment" : "Settings window → Extensions/Add-ons tab.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Extensions are loaded at launch via the native WebKit extension API. Changes take effect after restarting KasetPlus."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تحميل الإضافات عند التشغيل عبر واجهة WebKit الأصلية للإضافات. تسري التغييرات بعد إعادة تشغيل KasetPlus."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
