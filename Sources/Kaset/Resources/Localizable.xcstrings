          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erweiterungen werden beim Start über die native WebKit-Erweiterungs-API geladen. Änderungen werden nach einem Neustart von KasetPlus wirksam."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Extensions are loaded at launch via the native WebKit extension API. Changes take effect after restarting KasetPlus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las extensiones se cargan al iniciar mediante la API nativa de extensiones de WebKit. Los cambios se aplican después de reiniciar KasetPlus."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Extensions are loaded at launch via the native WebKit extension API. Changes take effect after restarting KasetPlus."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
