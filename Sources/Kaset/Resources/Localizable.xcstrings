    "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتوهج خلف المشغّل وهج لوني ناعم مستمد من الفيديو. ينطبق على فيديوهات YouTube، وليس Music."
          }
        },
