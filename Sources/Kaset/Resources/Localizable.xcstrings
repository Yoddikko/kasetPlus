    "Note: If passkeys don't work, use \"Try another way\" to sign in with password." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Note: If passkeys don't work, use \"Try another way\" to sign in with password."
