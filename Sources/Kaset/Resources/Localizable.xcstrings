    "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music." : {
      "comment" : "Settings window → YouTube tab (YouTube video playback, ambient backdrop, SponsorBlock/DeArrow).",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتوهج خلف المشغّل وهج لوني ناعم مستمد من الفيديو. ينطبق على فيديوهات YouTube، وليس Music."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Měkká barva vykreslená z videa přehrávaného za přehrávačem. Používá se na YouTube videa, nikoli na hudbu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En blød farve glød trukket fra videoen spiller bag afspilleren. Gælder for YouTube-videoer, ikke musik."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinter dem Player erscheint ein weicher Farbschimmer aus dem Video. Gilt für YouTube-Videos, nicht für Music."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μια απαλή λάμψη από το βίντεο παίζει πίσω από τον παίκτη. Ισχύει για βίντεο στο YouTube, όχι για μουσική."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra detrás del reproductor un suave resplandor de color extraído del video. Se aplica a videos de YouTube, no a Music."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pehmeä väri, joka on piirretty soittimen takana olevasta videosta. Koskee YouTube-videoita, ei musiikkia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Affiche derrière le lecteur une douce lueur colorée tirée de la vidéo. S'applique aux vidéos YouTube, pas à Music."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menampilkan cahaya warna lembut dari video di belakang pemutar. Berlaku untuk video YouTube, bukan Music."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estrae il colore dal video in riproduzione e lo trasforma in una sfumatura che appare dietro l'interfaccia. Compatibile con video di YouTube, non con Music."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレーヤーの背後にある動画から描かれた柔らかい色の輝きが再生されます。音楽ではなくYouTubeの動画に適用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비디오에서 가져온 부드러운 색상 빛이 플레이어 뒤에 표시됩니다. YouTube 동영상에만 적용되며 Music에는 적용되지 않습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toont achter de speler een zachte kleurglans uit de video. Geldt voor YouTube-video's, niet voor Music."
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En myk farge glød fra videoen spiller bak spilleren. Legger til YouTube-videoer, ikke Musikk."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Za odtwarzaczem wyświetla się delikatna poświata kolorów pobrana z filmu. Dotyczy filmów YouTube, nie Music."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra atrás do leitor um brilho suave de cor extraído do vídeo. Aplica-se a vídeos do YouTube, não ao Music."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um brilho de cores fácil desenhado do vídeo é reproduzido por trás do reprodutor. Aplica-se aos vídeos do YouTube, não à música."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O strălucire de culoare moale desenată din videoclipul redă în spatele playerului. Se aplică videoclipurilor de pe YouTube, nu muzicii."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Позади проигрывателя появляется мягкое цветное свечение, взятое из видео. Применяется к видео YouTube, а не к Music."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett mjukt färgskimmer från videon visas bakom spelaren. Gäller YouTube-videor, inte Music."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oynatıcının arkasında videodan alınan yumuşak bir renk parıltısı görünür. YouTube videoları için geçerlidir, Music için değil."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Позаду програвача з’являється м’яке кольорове сяйво з відео. Застосовується до відео YouTube, а не до Music."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从播放器背后的视频画出软色光。适用于YouTube视频，而不是音乐。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A soft color glow drawn from the video plays behind the player. Applies to YouTube videos, not Music."
          }
        }
      }
    },
