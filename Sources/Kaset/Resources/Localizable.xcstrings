    "\"Live\" shifts the colors as the video plays; the others stay constant" : {
      "comment" : "Help text under the ambient-backdrop style picker (YouTube settings).",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يغيّر \"مباشر\" الألوان أثناء تشغيل الفيديو؛ بينما تبقى الخيارات الأخرى ثابتة"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Život\" mění barvy při přehrávání videa; ostatní zůstávají konstantní"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Levende\" skifter farverne som videoen afspiller; de andre forbliver konstant"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" verändert die Farben während der Wiedergabe des Videos, die anderen bleiben konstant"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" μετατοπίζει τα χρώματα όπως τα video plays; οι άλλοι παραμένουν σταθερά"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"En vivo\" cambia los colores a medida que se reproduce el video; los demás permanecen constantes"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" muuttaa värejä kuin video, muut pysyvät vakiona"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"En direct\" fait évoluer les couleurs pendant la lecture de la vidéo ; les autres restent constantes"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" mengubah warna saat video diputar; yang lain tetap konstan"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" altera i colori durante la riproduzione del video; gli altri colori rimangono costanti"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「ライブ」はビデオが再生されるたびに色を変えます。他の人は一定のままにします"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"실시간\"은 비디오 재생에 따라 색상이 변하고, 다른 옵션은 고정됩니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" laat de kleuren mee veranderen terwijl de video afspeelt; de andere blijven constant"
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" skift farger som videospiller; andre holder seg konstant"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Na żywo\" zmienia kolory podczas odtwarzania filmu; pozostałe pozostają stałe"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ao vivo\" altera as cores à medida que o vídeo é reproduzido; os restantes mantêm-se constantes"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" desloca as cores como o vídeo reproduz; os outros permanecem constantes"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Viu\" schimbă culorile ca redare video, iar celelalte rămân constante"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"В эфире\" меняет цвета по мере воспроизведения видео; остальные остаются постоянными"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" skiftar färgerna medan videon spelas; de andra förblir oförändrade"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Canlı\", video oynatıldıkça renkleri değiştirir; diğerleri sabit kalır"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Наживо\" змінює кольори під час відтворення відео; інші варіанти залишаються сталими"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Live”在视频播放时改变颜色；其他人保持常量"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        }
      }
    },
