        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ملاحظة: إذا لم تعمل مفاتيح المرور، فاستخدم \"جرّب طريقة أخرى\" لتسجيل الدخول بكلمة المرور."
