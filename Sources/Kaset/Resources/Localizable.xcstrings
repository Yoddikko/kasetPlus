    "When enabled, KasetPlus can add richer queue analysis, AI-powered playlist refinement, and lyrics explanations." : {
      "comment" : "Settings window → Intelligence tab (on-device Apple Intelligence features: AI command bar, playlist refinement, lyrics explanations).",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When enabled, KasetPlus can add richer queue analysis, AI-powered playlist refinement, and lyrics explanations."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند التفعيل، يمكن لـ KasetPlus إضافة تحليل أعمق لقائمة الانتظار، وتحسين قوائم التشغيل بالذكاء الاصطناعي، وشرح كلمات الأغاني."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When enabled, KasetPlus can add richer queue analysis, AI-powered playlist refinement, and lyrics explanations."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When enabled, KasetPlus can add richer queue analysis, AI-powered playlist refinement, and lyrics explanations."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When enabled, KasetPlus can add richer queue analysis, AI-powered playlist refinement, and lyrics explanations."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn diese Option aktiviert ist, kann KasetPlus eine umfassendere Warteschlangenanalyse, KI-gestützte Playlist-Verfeinerung und Songtext-Erklärungen hinzufügen."
