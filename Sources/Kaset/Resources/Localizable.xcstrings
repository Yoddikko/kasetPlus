    "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue" : {
      "comment" : "Settings window → Music tab (YouTube Music playback and library options).",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يضيف حالة \"ذكية\" ثالثة إلى زر الخلط لإدراج المقطوعات المقترحة ضمن قائمة التشغيل"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přidá třetí stav 'smart' do náhodného tlačítka, které přepíná doporučené skladby do vaší fronty"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tilføjer en tredje 'smart' tilstand til shuffle knappen, der krydser anbefalede spor i din kø"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügt der Taste für die Zufallswiedergabe einen dritten „intelligenten“ Zustand hinzu, der empfohlene Titel in deine Warteschlange einstreut"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Προσθέτει μια τρίτη 'έξυπνη' κατάσταση στο κουμπί ανακατέματος που αφήνει τα συνιστώμενα κομμάτια στην ουρά σας"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un tercer estado \"inteligente\" al botón de aleatorio que intercala pistas recomendadas en tu cola"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lisää kolmannen älykkään tilan sekoituspainikkeeseen, joka leikkaa suositellut kappaleet jonoosi"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoute un troisième état « intelligent » au bouton de lecture aléatoire qui intègre des titres recommandés à votre file d’attente"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menambahkan status \"cerdas\" ketiga ke tombol acak yang menyisipkan trek rekomendasi ke antrean Anda"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiunge un terzo stato 'intelligente' al pulsante Casuale che intreccia i brani consigliati nella tua coda"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "おすすめのトラックをキューに入れるシャッフルボタンに 3 つ目の「スマート」状態を追加します"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "셔플 버튼에 추천 트랙을 대기열에 끼워 넣는 세 번째 '스마트' 상태를 추가합니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voegt een derde 'slimme' stand toe aan de shuffleknop die aanbevolen nummers tussen je wachtrij plaatst"
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legger til en tredje 'smart' tilstand på shuffle-knappen som blinker med anbefalte spor i køen"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodaje trzeci, „inteligentny” stan do przycisku losowania, który przeplata polecane utwory z Twoją kolejką"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adiciona um terceiro estado \"inteligente\" ao botão Aleatório que intercala faixas recomendadas na sua fila"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adiciona um terceiro estado 'inteligente' ao botão de embaralhar que intercepta faixas recomendadas em sua fila"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaugă o a treia stare 'inteligentă' la butonul de amestecare, care interferează melodiile recomandate în coada de așteptare"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляет третье «умное» состояние кнопке перемешивания, которое вставляет рекомендованные треки в вашу очередь"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lägger till ett tredje ”smart” läge på blandningsknappen som väver in rekommenderade spår i din kö"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karıştırma düğmesine, önerilen parçaları kuyruğunuza ekleyen üçüncü bir \"akıllı\" durum ekler"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Додає третій «розумний» стан кнопки перемішування, який чергує рекомендовані треки у вашій черзі"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将第三个“智能”状态添加到随机按钮，将推荐曲目交出到您的队列中"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue"
          }
