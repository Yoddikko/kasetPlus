    "Clears the AI session state. Use this if responses seem off or stuck." : {
      "comment" : "Help text under the 'Clear AI Context' button in Intelligence settings.",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Clears the AI session state. Use this if responses seem off or stuck."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمسح حالة جلسة الذكاء الاصطناعي. استخدمه إذا بدت الاستجابات غير صحيحة أو متوقفة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Clears the AI session state. Use this if responses seem off or stuck."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vymaže stav AI relace. Použijte tuto možnost, pokud se odpovědi zdají být vypnuty nebo uvízly."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rydder AI-sessionen. Brug dette hvis svarene synes ud eller sidder fast."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löscht den Status der KI-Sitzung. Verwende dies, wenn Antworten unpassend wirken oder festhängen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Καθαρίζει την κατάσταση συνεδρίας τεχνητής νοημοσύνης. Χρησιμοποιήστε το αν οι απαντήσεις φαίνονται εκτός λειτουργίας ή κολλήσουν."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borra el estado de la sesión de la IA. Úsalo si las respuestas parecen incorrectas o atascadas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
