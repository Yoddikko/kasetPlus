    "Show playback controls overlaid on the video (on hover) instead of in the docked bar at the bottom." : {
      "comment" : "Settings window → YouTube tab (YouTube video playback, ambient backdrop, SponsorBlock/DeArrow).",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Show playback controls overlaid on the video (on hover) instead of in the docked bar at the bottom."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إظهار عناصر التحكم في التشغيل الموجودة على الفيديو (داخل الحافلة) بدلا من الشريط المربوط في الأسفل."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Show playback controls overlaid on the video (on hover) instead of in the docked bar at the bottom."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zobrazit ovládací prvky přehrávání překryté na videu (při přejetí) namísto v dokovaném panelu v dolní části."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vis afspilningskontroller overlejret på videoen (på svæver) i stedet for i den dockede bjælke nederst."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeige Wiedergabe-Steuerelemente überlagert auf dem Video (schweben) statt in der angedockten Leiste unten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εμφάνιση στοιχείων ελέγχου αναπαραγωγής με επικάλυψη στο βίντεο (στο hover) αντί στη γραμμή σύνδεσης στο κάτω μέρος."
