    "\"Live\" shifts the colors as the video plays; the others stay constant" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يغيّر \"مباشر\" الألوان أثناء تشغيل الفيديو؛ بينما تبقى الخيارات الأخرى ثابتة"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" verändert die Farben während der Wiedergabe des Videos, die anderen bleiben konstant"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"En vivo\" cambia los colores a medida que se reproduce el video; los demás permanecen constantes"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"En direct\" fait évoluer les couleurs pendant la lecture de la vidéo ; les autres restent constantes"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" mengubah warna saat video diputar; yang lain tetap konstan"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" modifica i colori durante la riproduzione del video; gli altri restano costanti"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"실시간\"은 비디오 재생에 따라 색상이 변하고, 다른 옵션은 고정됩니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" laat de kleuren mee veranderen terwijl de video afspeelt; de andere blijven constant"
          }
        },
        "no" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Na żywo\" zmienia kolory podczas odtwarzania filmu; pozostałe pozostają stałe"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ao vivo\" altera as cores à medida que o vídeo é reproduzido; os restantes mantêm-se constantes"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"В эфире\" меняет цвета по мере воспроизведения видео; остальные остаются постоянными"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Live\" shifts the colors as the video plays; the others stay constant"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Live\" skiftar färgerna medan videon spelas; de andra förblir oförändrade"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Canlı\", video oynatıldıkça renkleri değiştirir; diğerleri sabit kalır"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Наживо\" змінює кольори під час відтворення відео; інші варіанти залишаються сталими"
          }
        },
        "vi" : {
